{
  "manifest_version": 3,
  "name": "Save with Timson",
  "version": "2.1.0",
  "description": "Automatically finds and tries discount codes on Shopify checkouts",
  "permissions": ["activeTab", "scripting", "storage", "alarms"],
  "host_permissions": [
    "https://old.reddit.com/*",
    "https://www.retailmenot.com/*",
    "https://www.coupons.com/*"
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background/service-worker.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "*://*.myshopify.com/checkouts/*"
      ],
      "js": ["content/shopify.js"],
      "run_at": "document_idle"
    }
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
